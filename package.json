{
  "name": "sneakbit-html",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test tests/*.test.js",
    "test:e2e": "node --test --test-timeout=120000 --test-concurrency=1 tests/e2e/*.test.mjs",
    "serve": "python3 -m http.server 8000"
  }
}
